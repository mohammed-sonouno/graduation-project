# =============================================================================
# Environment variables — copy this file to .env and fill in real values.
# Never commit .env; it is listed in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Frontend (Vite)
# -----------------------------------------------------------------------------
# Google OAuth: create a Web application client at https://console.cloud.google.com/apis/credentials
# Add http://localhost:3000 to Authorized JavaScript origins (Vite dev port). Optional: http://localhost:5173. Leave empty to hide "Sign in with Google".
VITE_GOOGLE_CLIENT_ID=

# Backend API base URL. Leave empty so the browser calls relative /api (Vite dev + vite preview proxy to backend).
# Do not set this to the same URL as the UI (e.g. http://localhost:3000) — you may get HTML instead of JSON.
# For a split deploy only, set e.g. VITE_API_URL=https://api.example.com
VITE_API_URL=

# -----------------------------------------------------------------------------
# Backend (Node)
# -----------------------------------------------------------------------------
# Server port (default: 2000)
PORT=2000

# Secret for JWT/session signing. Use a long random string in production.
JWT_SECRET=your-jwt-secret-change-in-production

# PostgreSQL connection string. Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Encode special characters: @ → %40, $ → %24, space → %20
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/graduation_project

# Allowed CORS origins (comma-separated). Default: http://localhost:3000, http://localhost:5173
# CORS_ORIGIN=http://localhost:5173,https://your-app.example.com

# -----------------------------------------------------------------------------
# Email (login codes) — optional; if unset, codes are logged only
# -----------------------------------------------------------------------------
# Gmail: enable 2-Step Verification, then create an App Password (Security → App passwords).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-16-char-app-password
# EMAIL_FROM=Graduation Project <your-email@gmail.com>

# Other SMTP (uncomment and set):
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=Graduation Project <noreply@example.com>

# -----------------------------------------------------------------------------
# Chat ML (optional) — active artifact versions after offline training + deploy.
# Does not load models in Node by default; use for ops / Python parity.
# -----------------------------------------------------------------------------
# CHAT_ML_INTENT_MODEL_VERSION=
# CHAT_ML_RANK_MODEL_VERSION=
# CHAT_ML_SYNONYM_MODEL_VERSION=
#
# Include engine `debug` on POST /api/chat (default: on when NODE_ENV is not production).
# CHATBOT_DEBUG=0
