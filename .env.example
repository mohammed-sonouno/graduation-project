# Google OAuth (required for "Sign in with Google")
# Create a OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Application type: Web application. Add http://localhost:5173 to Authorized JavaScript origins.
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Backend API base URL (optional). If unset, Vite dev server proxies /api to http://localhost:3001
# Set when backend runs on another host/port in production, e.g.:
# VITE_API_URL=https://api.example.com

# Backend: PostgreSQL. Optional. If unset, app uses default:
#   Host: 10.20.10.20, Port: 5433, User: postgres, Database: graduation Project
# Set DATABASE_URL only to override (format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE; encode @ and $ as %40 and %24).
# DATABASE_URL=postgresql://postgres:YourPass%40%24@10.20.10.20:5433/graduation%20Project

# Backend: Email (login codes). Optional. If unset, codes are logged only (no email sent).
# --- Gmail (recommended) ---
# 1. Use a Gmail account (e.g. your-university@gmail.com or a dedicated noreply account).
# 2. Enable 2-Step Verification: Google Account → Security → 2-Step Verification.
# 3. Create an App Password: Google Account → Security → 2-Step Verification → App passwords → Generate (choose "Mail" and your device). Copy the 16-character password.
# 4. Set these in .env (do NOT commit .env):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-gmail@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# EMAIL_FROM=Graduation Project <your-gmail@gmail.com>
# --- Other SMTP ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# EMAIL_FROM=Graduation Project <noreply@example.com>
