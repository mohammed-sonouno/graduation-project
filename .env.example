# Copy to .env and adjust. .env is gitignored; this file is committed so ports and config are in the repo.

# Backend (server)
PORT=2000

# Frontend uses port 3000 (see vite.config.js). Proxy /api -> http://localhost:2000
# Optional: override API URL when frontend runs elsewhere (e.g. production)
# VITE_API_URL=

# CORS origins (comma-separated). Default in code: http://localhost:3000, http://localhost:5173
# CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Production: set NODE_ENV=production and provide DATABASE_URL, JWT_SECRET (and optionally ADMIN_EMAIL, ADMIN_PASSWORD).
# NODE_ENV=production

# Database (required in production; optional in dev — server has a dev default)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# JWT secret (required in production; optional in dev)
# JWT_SECRET=your-long-random-secret

# Admin bootstrap (optional; used to create/refresh admin@najah.edu on startup if not set in dev)
# ADMIN_EMAIL=admin@najah.edu
# ADMIN_PASSWORD=change-me

# SMTP for login codes / email (optional)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
